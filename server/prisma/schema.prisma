generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────

enum OrgType {
  AGENCY
  UMBRELLA
}

enum MemberRole {
  ADMIN
  CONSULTANT
  PAYROLL_OPERATOR
  CONTRACTOR
}

enum AuditEventType {
  USER_CREATED
  USER_ROLE_CHANGED
  ORG_CREATED
  CONTRACTOR_LINKED
  LOGIN
}

// ─── Organisation ────────────────────────────────────────

model Organisation {
  id        String   @id @default(uuid())
  name      String
  type      OrgType
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  memberships              OrgMembership[]
  contractors_as_agency    Contractor[] @relation("AgencyContractors")
  contractors_as_umbrella  Contractor[] @relation("UmbrellaContractors")
  auditLogs                AuditLog[]

  @@map("organisations")
}

// ─── User ────────────────────────────────────────────────

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  name         String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  memberships OrgMembership[]
  contractor  Contractor?
  auditLogs   AuditLog[]

  @@map("users")
}

// ─── OrgMembership ───────────────────────────────────────

model OrgMembership {
  id        String     @id @default(uuid())
  userId    String
  orgId     String
  role      MemberRole
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())

  user         User         @relation(fields: [userId], references: [id])
  organisation Organisation @relation(fields: [orgId], references: [id])

  @@unique([userId, orgId])
  @@map("org_memberships")
}

// ─── Contractor ──────────────────────────────────────────

model Contractor {
  id         String   @id @default(uuid())
  userId     String   @unique
  agencyId   String
  umbrellaId String
  taxCode    String?
  niNumber   String?
  hourlyRate Decimal  @default(0) @db.Decimal(10, 2)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user     User         @relation(fields: [userId], references: [id])
  agency   Organisation @relation("AgencyContractors", fields: [agencyId], references: [id])
  umbrella Organisation @relation("UmbrellaContractors", fields: [umbrellaId], references: [id])

  @@map("contractors")
}

// ─── AuditLog ────────────────────────────────────────────

model AuditLog {
  id           String         @id @default(uuid())
  actorId      String?
  actorRole    String?
  orgId        String?
  eventType    AuditEventType
  workRecordId String?
  beforeState  String?
  afterState   String?
  metadata     Json?
  createdAt    DateTime       @default(now())

  actor        User?         @relation(fields: [actorId], references: [id])
  organisation Organisation? @relation(fields: [orgId], references: [id])

  @@map("audit_logs")
}