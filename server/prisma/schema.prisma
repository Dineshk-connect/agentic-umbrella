generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────

enum OrgType {
  AGENCY
  UMBRELLA
}

enum MemberRole {
  ADMIN
  CONSULTANT
  PAYROLL_OPERATOR
  CONTRACTOR
}

enum AuditEventType {
  USER_CREATED
  USER_ROLE_CHANGED
  ORG_CREATED
  CONTRACTOR_LINKED
  LOGIN
  TIMESHEET_SUBMITTED
  TIMESHEET_APPROVED
  TIMESHEET_REJECTED
  WORK_RECORD_CREATED
  INVOICE_GENERATED
  INVOICE_APPROVED
  PAYMENT_RECEIVED
  PAYMENT_MISMATCH
}

// ─── Organisation ────────────────────────────────────────

model Organisation {
  id        String   @id @default(uuid())
  name      String
  type      OrgType
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  memberships              OrgMembership[]
  contractors_as_agency    Contractor[] @relation("AgencyContractors")
  contractors_as_umbrella  Contractor[] @relation("UmbrellaContractors")
  auditLogs                AuditLog[]
  agencyWorkRecords   WorkRecord[] @relation("AgencyWorkRecords")
  umbrellaWorkRecords WorkRecord[] @relation("UmbrellaWorkRecords")
  agencyInvoices    Invoice[] @relation("AgencyInvoices")
  umbrellaInvoices  Invoice[] @relation("UmbrellaInvoices")

  @@map("organisations")
}

// ─── User ────────────────────────────────────────────────

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  name         String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  memberships OrgMembership[]
  contractor  Contractor?
  auditLogs   AuditLog[]

  @@map("users")
}

// ─── OrgMembership ───────────────────────────────────────

model OrgMembership {
  id        String     @id @default(uuid())
  userId    String
  orgId     String
  role      MemberRole
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())

  user         User         @relation(fields: [userId], references: [id])
  organisation Organisation @relation(fields: [orgId], references: [id])

  @@unique([userId, orgId])
  @@map("org_memberships")
}

// ─── Contractor ──────────────────────────────────────────

model Contractor {
  id         String   @id @default(uuid())
  userId     String   @unique
  agencyId   String
  umbrellaId String
  taxCode    String?
  niNumber   String?
  hourlyRate Decimal  @default(0) @db.Decimal(10, 2)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user     User         @relation(fields: [userId], references: [id])
  agency   Organisation @relation("AgencyContractors", fields: [agencyId], references: [id])
  umbrella Organisation @relation("UmbrellaContractors", fields: [umbrellaId], references: [id])
  workRecords WorkRecord[]
  timesheets  Timesheet[]
  invoices Invoice[]

  @@map("contractors")
}

// ─── AuditLog ────────────────────────────────────────────

model AuditLog {
  id           String         @id @default(uuid())
  actorId      String?
  actorRole    String?
  orgId        String?
  eventType    AuditEventType
  workRecordId String?
  beforeState  String?
  afterState   String?
  metadata     Json?
  createdAt    DateTime       @default(now())

  actor        User?         @relation(fields: [actorId], references: [id])
  organisation Organisation? @relation(fields: [orgId], references: [id])
  workRecord   WorkRecord?   @relation("WorkRecordAuditLogs", fields: [workRecordId], references: [id])

  @@map("audit_logs")
}

// ─── Work Record State Machine ───────────────────────────

enum WorkRecordState {
  WORK_SUBMITTED
  WORK_APPROVED
  WORK_REJECTED
  INVOICE_GENERATED
  INVOICE_APPROVED
  PAYMENT_PENDING
  PAYMENT_RECEIVED
  PAYROLL_PROCESSING
  PAYROLL_COMPLETED
  COMPLIANCE_SUBMITTED
  COMPLETED
}

// ─── WorkRecord (the central object — one per timesheet cycle) ───

model WorkRecord {
  id          String          @id @default(uuid())
  contractorId String
  agencyId    String
  umbrellaId  String
  state       WorkRecordState @default(WORK_SUBMITTED)
  version     Int             @default(1)  // optimistic locking
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  contractor  Contractor   @relation(fields: [contractorId], references: [id])
  agency      Organisation @relation("AgencyWorkRecords", fields: [agencyId], references: [id])
  umbrella    Organisation @relation("UmbrellaWorkRecords", fields: [umbrellaId], references: [id])

  timesheets  Timesheet[]
  auditLogs   AuditLog[]   @relation("WorkRecordAuditLogs")
  invoice Invoice?

  @@map("work_records")
}

// ─── Timesheet (version-controlled) ──────────────────────

model Timesheet {
  id           String   @id @default(uuid())
  workRecordId String
  contractorId String
  weekStarting DateTime
  hoursWorked  Decimal  @db.Decimal(6, 2)
  hourlyRate   Decimal  @db.Decimal(10, 2)
  totalAmount  Decimal  @db.Decimal(10, 2)
  notes        String?
  version      Int      @default(1)
  isActive     Boolean  @default(true)  // only latest version is active
  createdAt    DateTime @default(now())

  workRecord   WorkRecord @relation(fields: [workRecordId], references: [id])
  contractor   Contractor @relation(fields: [contractorId], references: [id])

  @@map("timesheets")
}

// ─── Invoice & Payment Enums ─────────────────────────────

enum InvoiceState {
  INVOICE_GENERATED
  INVOICE_APPROVED
  PAYMENT_PENDING
  PAYMENT_RECEIVED
}

// ─── Invoice ─────────────────────────────────────────────

model Invoice {
  id            String       @id @default(uuid())
  workRecordId  String       @unique  // one invoice per work record
  agencyId      String
  umbrellaId    String
  contractorId  String
  amount        Decimal      @db.Decimal(10, 2)
  currency      String       @default("GBP")
  state         InvoiceState @default(INVOICE_GENERATED)
  invoiceNumber String       @unique
  dueDate       DateTime
  paidAt        DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  workRecord   WorkRecord   @relation(fields: [workRecordId], references: [id])
  agency       Organisation @relation("AgencyInvoices", fields: [agencyId], references: [id])
  umbrella     Organisation @relation("UmbrellaInvoices", fields: [umbrellaId], references: [id])
  contractor   Contractor   @relation(fields: [contractorId], references: [id])
  payments     Payment[]

  @@map("invoices")
}

// ─── Payment ─────────────────────────────────────────────

model Payment {
  id              String   @id @default(uuid())
  invoiceId       String
  amount          Decimal  @db.Decimal(10, 2)
  currency        String   @default("GBP")
  reference       String   @unique  // bank transfer reference
  fromAccount     String            // agency bank account
  status          String   @default("PENDING")  // PENDING | MATCHED | MISMATCHED
  receivedAt      DateTime @default(now())
  reconciledAt    DateTime?
  createdAt       DateTime @default(now())

  invoice         Invoice  @relation(fields: [invoiceId], references: [id])

  @@map("payments")
}